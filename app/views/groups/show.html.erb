<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-end mb-4">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><%= link_to "Wszystkie grupy", groups_path, class: "text-decoration-none" %></li>
          <li class="breadcrumb-item active"><%= @group.name %></li>
        </ol>
      </nav>
      <h2 class="fw-bold mb-0">Kabinet rodzinny</h2>
    </div>

    <div class="d-flex gap-2">
      <%= link_to edit_group_path(@group), class: "btn btn-outline-primary shadow-sm btn-sm" do %>
        <i class="fa-regular fa-pen-to-square me-1"></i> Ustawienia
      <% end %>
      <%= button_to group_path(@group), method: :delete, class: "btn btn-outline-danger shadow-sm btn-sm", data: { turbo_confirm: "Usunąć grupu?" } do %>
        <i class="fa-regular fa-trash-can me-1"></i> Usunąć
      <% end %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-3 mb-4">
      <div class="sticky-top" style="top: 100px;">
        <%= render 'sidebar' %> </div>
    </div>

    <div class="col-md-9">
      <div class="card shadow-sm border-0 mb-4 overflow-hidden">
        <div style="height: 6px; background: linear-gradient(90deg, #0d6efd 0%, #6610f2 100%);"></div>
        <div class="card-body p-4">
          <div class="d-flex align-items-center mb-3">
            <h1 class="fw-bold mb-0 me-3"><%= @group.name %></h1>
            <span class="badge bg-primary rounded-pill"><%= @group.privacy %></span>
          </div>
          <p class="text-muted"><%= @group.description.present? ? @group.description : "Opis rodziny nie został jeszcze wypełniony..." %></p>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 pt-3">
              <h5 class="fw-bold mb-0">Skład rodziny</h5>
            </div>
            <div class="card-body">
              <% if @group.ancestors.any? %>
                <ul class="list-group list-group-flush">
                  <% @group.ancestors.limit(5).each do |person| %>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                      <%= person.full_name %>
                      <%= link_to "→", group_ancestor_path(@group, person), class: "text-decoration-none text-primary" %>
                    </li>
                  <% end %>
                </ul>
                <%= link_to "Wszystkie persony (#{@group.ancestors.count})", group_ancestors_path(@group), class: "btn btn-link btn-sm p-0 mt-2 text-decoration-none" %>
              <% else %>
                <p class="text-muted small">W tej grupie nie ma jeszcze dodanych osób</p>
              <% end %>
            </div>
          </div>
        </div>

        <div class="col-md-6 mb-4">
          <div class="card shadow-sm border-0 h-100 bg-primary text-white">
            <div class="card-body d-flex flex-column justify-content-center text-center p-4">
              <i class="fa-solid fa-tree fa-3x mb-3"></i>
              <h5 class="fw-bold">Drzewo genealogiczne</h5>
              <p class="small opacity-75">Zobacz wizualny schemat swojego rodu</p>
              <%= link_to "Otwórz drzewo", tree_group_path(@group), class: "btn btn-light fw-bold rounded-pill mt-auto" %>
            </div>
          </div>
        </div>
      </div>

      <div class="card bg-light border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
          <h5 class="fw-bold"><i class="fa-solid fa-hand-holding-heart text-primary me-2"></i>Witamy w archiwum</h5>
          <p class="mb-0 text-secondary small">
            Twoja historia zaczyna się tutaj. Dodawaj przodków i buduj drzewo genealogiczne
          </p>
        </div>
      </div>

    </div>
  </div>
</div>