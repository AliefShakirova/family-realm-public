<div class="row mt-4">
  <div class="col-md-3">
    <%= render "sidebar" %>
  </div>

  <div class="col-md-9">

    <h5 class="text-muted">Описание:</h5>
    <p class="lead"><%= @group.description %></p>

    <hr>

    <div class="d-flex justify-content-between align-items-center">
      <small class="text-muted">Управление группой</small>

      <div class="btn-group">
        <%= link_to "Редактировать", edit_group_path(@group), class: "btn btn-outline-primary" %>

        <%= button_to "Удалить группу",
                      group_path(@group),
                      method: :delete,
                      class: "btn btn-danger",
                      form: { style: 'display:inline-block;' },
                      data: { turbo_confirm: "Вы уверены? Это удалит ВСЕ данные семьи безвозвратно!" }
        %>
      </div>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <h1 class="display-5"><%= @group.name %></h1>
        <span class="badge bg-primary mb-3"><%= @group.privacy || "Private" %></span>
        <h5 class="text-muted">Описание:</h5>
        <p class="lead"><%= @group.description %></p>
      </div>
    </div>

    <div class="alert alert-light border">
      <h4>Добро пожаловать в архив семьи!</h4>
      <p>Используйте меню слева для навигации по разделам: добавляйте предков, отмечайте памятные места и приглашайте
        родственников.</p>
    </div>

  </div>
</div>