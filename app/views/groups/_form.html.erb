<%= form_with model: @group do |f| %>
  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :privacy %>
    <%= f.select :privacy, [['Открытая', 'public'], ['Закрытая', 'private']] %>
  </div>

  <%= f.submit %>
<% end %>
