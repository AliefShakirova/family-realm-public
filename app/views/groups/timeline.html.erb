<style>
    .custom-timeline {
        border-left: 3px solid #0d6efd;
        padding-left: 30px;
        position: relative;
        margin-left: 20px;
    }
    .timeline-item {
        margin-bottom: 30px;
        position: relative;
    }
    .timeline-item::before {
        content: '';
        width: 20px;
        height: 20px;
        background-color: #0d6efd;
        border: 4px solid #fff;
        border-radius: 50%;
        position: absolute;
        left: -41.5px;
        top: 5px;
        box-shadow: 0 0 0 2px #0d6efd;
    }
    .timeline-date {
        font-weight: bold;
        color: #0d6efd;
        margin-bottom: 5px;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>⏳ Семейная ось времени</h1>
  <%= link_to "Назад к группе", group_ancestors_path(@group), class: "btn btn-outline-secondary" %>
</div>

<div class="row">
  <div class="col-md-8">
    <div class="card shadow-sm border-0 p-4">
      <% if @timeline_events.any? %>
        <div class="custom-timeline">
          <% @timeline_events.each do |event| %>
            <div class="timeline-item">
              <div class="timeline-date">
                <%= event.event_date.strftime("%d.%m.%Y") if event.event_date %>
              </div>
              <div class="card bg-light border-0 shadow-sm mt-2">
                <div class="card-body">
                  <h5 class="card-title text-dark"><%= event.title %></h5>

                  <% if event.ancestor_id.present? %>
                    <% person = @ancestors.find_by(id: event.ancestor_id) %>
                    <% if person %>
                      <span class="badge bg-info text-dark mb-2">
                        👤 <%= person.full_name %>
                      </span>
                    <% end %>
                  <% end %>

                  <p class="card-text text-muted mb-0"><%= event.description %></p>
                  <div class="mt-3 text-end">
                    <% if event.persisted? %>
                      <%= link_to "✏️ Редактировать", edit_timeline_event_path(event), class: "btn btn-sm btn-outline-secondary" %>

                      <%= form_with url: timeline_event_path(event), method: :delete, class: "d-inline" do |f| %>
                        <%= f.submit "🗑️ Удалить", class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: 'Точно удалить это событие?' } %>
                      <% end %>
                    <% else %>
                      <small class="text-muted" style="font-size: 0.8rem;">(Данные берутся из профиля персоны)</small>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center text-muted my-5">
          <h3>Ось времени пока пуста</h3>
          <p>Добавьте первое событие в панели справа.</p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0">➕ Добавить событие</h5>
      </div>
      <div class="card-body">
        <%= form_with url: add_timeline_event_group_path(@group), method: :post, local: true do |f| %>

          <div class="mb-3">
            <label class="form-label fw-bold">Что произошло?</label>
            <%= f.text_field :title, class: "form-control", placeholder: "Например: Свадьба, Переезд...", required: true %>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Дата события</label>
            <%= f.date_field :event_date, class: "form-control", required: true %>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Связать с персоной (необязательно)</label>
            <%= f.select :ancestor_id, options_from_collection_for_select(@ancestors, :id, :full_name), { prompt: "Выберите родственника..." }, { class: "form-select" } %>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Описание / История</label>
            <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Краткая история или детали..." %>
          </div>

          <%= f.submit "Добавить на ось", class: "btn btn-success w-100" %>
        <% end %>
      </div>
    </div>
  </div>
</div>