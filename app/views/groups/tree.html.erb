<div class="d-flex justify-content-between align-items-center mb-4">
  <h1> Drzewo rodzinne</h1>
  <%= link_to "Do listy osób", group_ancestors_path(@group), class: "btn btn-outline-primary" %>
</div>

<div class="row">
  <div class="col-md-9">
    <div class="card shadow-sm" style="min-height: 600px; background-color: #fcfcfc; background-image: radial-gradient(#d7d7d7 1px, transparent 1px); background-size: 20px 20px;">
      <div class="card-body text-center" style="overflow-x: auto;">

        <% if @chart_data.include?("-->") || @ancestors.count > 0 %>
          <div class="mermaid">
            <%= @chart_data.html_safe %>
          </div>
        <% else %>
          <div class="text-muted mt-5">
            <h3 style="color: #adb5bd;">Płótno jest puste</h3>
            <p>Dodaj połączenia w panelu po prawej stronie, aby pojawiło się drzewo</p>
          </div>
        <% end %>

      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-light">
        <h5 class="mb-0 m-1">Utwórz połączenie</h5>
      </div>
      <div class="card-body">
        <p class="text-muted small">Wybierz dwie osoby i określ, kim są dla siebie nawzajem</p><a href=""></a>

        <%= form_with url: make_connection_group_path(@group), method: :post, local: true do |f| %>
          <div class="mb-3">
            <label class="form-label fw-bold">Kto (Dzicko):</label>
            <%= f.select :child_id, options_from_collection_for_select(@ancestors, :id, :full_name), { prompt: "Wybierz osobę..." }, { class: "form-select", required: true } %>
          </div>

          <div class="mb-3 text-center">
            <span class="badge bg-secondary">jest dzieckiem dla</span>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Rodzic:</label>
            <%= f.select :parent_id, options_from_collection_for_select(@ancestors, :id, :full_name), { prompt: "Wybierz rodzica..." }, { class: "form-select", required: true } %>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Роль:</label>
            <%= f.select :role, [["To jest matka", "mother"], ["To Ojciec", "father"]], {}, { class: "form-select" } %>
          </div>

          <%= f.submit "Połączyć osoby", class: "btn btn-primary w-100" %>
        <% end %>

      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/mermaid@9.4.3/dist/mermaid.min.js"></script>
<script>
    mermaid.initialize({ startOnLoad: true, theme: 'default' });
</script>