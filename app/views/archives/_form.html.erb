<%= form_with(model: archive) do |form| %>
  <% if archive.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(archive.errors.count, "error") %> prohibited this archive from being saved:</h2>

      <ul>
        <% archive.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.text_area :description %>
  </div>

  <div>
    <%= form.label :gubernia, style: "display: block" %>
    <%= form.text_field :gubernia %>
  </div>

  <div>
    <%= form.label :year, style: "display: block" %>
    <%= form.number_field :year %>
  </div>

  <div class="mb-3">
    <%= form.label :document, "Załącz skan/dokument (PDF, JPG)", style: "display: block", class: "form-label fw-bold" %>
    <%= form.file_field :document, class: "form-control" %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
