<div class="container mt-5">
  <div class="card shadow-sm col-md-6 offset-md-3">
    <div class="card-header bg-primary text-white">
      <h4 class="mb-0">Edytuj wydarzenie</h4>
    </div>
    <div class="card-body">
      <%= form_with model: @timeline_event, local: true do |f| %>

        <div class="mb-3">
          <label class="form-label fw-bold">Co się wydarzyło?</label>
          <%= f.text_field :title, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Data wydarzenia</label>
          <%= f.date_field :event_date, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Powiązać z osobą</label>
          <%= f.select :ancestor_id, options_from_collection_for_select(@ancestors, :id, :full_name, @timeline_event.ancestor_id), { prompt: "Выберите родственника..." }, { class: "form-select" } %>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Opis</label>
          <%= f.text_area :description, class: "form-control", rows: 3 %>
        </div>

        <%= f.submit "Zapisz zmiany", class: "btn btn-success w-100 mb-2" %>
        <%= link_to "Anuluj", timeline_group_path(@group), class: "btn btn-outline-secondary w-100" %>
      <% end %>
    </div>
  </div>
</div>