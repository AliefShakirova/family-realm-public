<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card shadow-sm border-0" style="border-radius: 16px;">
        <div class="card-body p-5">

          <div class="text-center mb-4">
            <h2 class="fw-bold">Регистрация</h2>
            <p class="text-muted">Создайте свой семейный аккаунт</p>
          </div>

          <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="mb-3">
              <%= f.label :email, "Email", class: "form-label fw-medium" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg", placeholder: "name@example.com" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, "Пароль", class: "form-label fw-medium" %>
              <% if @minimum_password_length %>
                <small class="text-muted d-block mb-1">(Минимум <%= @minimum_password_length %> символов)</small>
              <% end %>
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control form-control-lg", placeholder: "••••••••" %>
            </div>

            <div class="mb-4">
              <%= f.label :password_confirmation, "Подтверждение пароля", class: "form-label fw-medium" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control form-control-lg", placeholder: "••••••••" %>
            </div>

            <%= f.submit "Зарегистрироваться", class: "btn btn-primary btn-lg w-100 mb-3" %>
          <% end %>

          <div class="text-center mt-3">
            <%= render "devise/shared/links" %>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>