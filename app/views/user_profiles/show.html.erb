<div class="row mt-4">
  <div class="col-md-3">
    <%= render "users/user_sidebar" %>
  </div>

  <div class="col-md-9">
    <div class="card shadow-sm">
      <div class="card-header bg-white">
        <h3 class="mb-0">Profil użytkownika</h3>
      </div>
      <div class="card-body">

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Imię</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.first_name.presence || "Nie wskazane" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Nazwisko</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.last_name.presence || "Nie wskazane" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Imię ojca</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.middle_name.presence || "Nie wskazane" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Nazwisko panieńskie</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.maiden_name.presence || "Nie wskazane" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Data urodzenia</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold">
              <%= @user_profile&.birth_date ? @user_profile.birth_date.strftime("%d.%m.%Y") : "Nie wskazane" %>
            </p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Miejsce urodzenia</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.place_of_birth.presence || "Nie wskazane" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Płeć</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.gender.presence || "Nie wskazane" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">O siebie</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.description.presence || "Nie wskazane" %></p>
          </div>
        </div>

        <hr>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Email</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext"><%= current_user.email %></p>
          </div>
        </div>

        <hr>

        <div class="d-flex">
          <%= link_to "Edytuj profil", edit_user_profile_path, class: "btn btn-primary me-2" %>
          <%= link_to "Zmienić hasło", edit_user_registration_path, class: "btn btn-outline-secondary" %>
        </div>

      </div>
    </div>
  </div>
</div>