<div class="row mt-4">
  <div class="col-md-3">
    <%= render "users/user_sidebar" %>
  </div>

  <div class="col-md-9">
    <div class="card shadow-sm">
      <div class="card-header bg-white">
        <h3 class="mb-0">Профиль пользователя</h3>
      </div>
      <div class="card-body">

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Имя</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.first_name.presence || "Не указано" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Фамилия</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.last_name.presence || "Не указано" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Отчество</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.middle_name.presence || "Не указано" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Девичья фамилия</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.maiden_name.presence || "Не указано" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Дата рождения</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold">
              <%= @user_profile&.birth_date ? @user_profile.birth_date.strftime("%d.%m.%Y") : "Не указано" %>
            </p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Место рождения</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.place_of_birth.presence || "Не указано" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Пол</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.gender.presence || "Не указано" %></p>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">О себе</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext fw-bold"><%= @user_profile&.description.presence || "Не указано" %></p>
          </div>
        </div>

        <hr>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label text-muted">Email</label>
          <div class="col-sm-9">
            <p class="form-control-plaintext"><%= current_user.email %></p>
          </div>
        </div>

        <hr>

        <div class="d-flex">
          <%= link_to "Редактировать профиль", edit_user_profile_path, class: "btn btn-primary me-2" %>
          <%= link_to "Сменить пароль", edit_user_registration_path, class: "btn btn-outline-secondary" %>
        </div>

      </div>
    </div>
  </div>
</div>