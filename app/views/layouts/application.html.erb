<!DOCTYPE html>
<html>
<head>
  <title>FamilyRealm</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css' %>
  <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
  <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
</head>

<body>

  <nav style="padding: 10px; background: #f5f5f5;">
    <% if user_signed_in? %>
      <span>Привет, <%= current_user.email %>!</span>
      <%= link_to "Профиль", user_profile_path %>
      <%= link_to "Выйти", destroy_user_session_path, method: :delete, style: "margin-left: 10px;" %>
    <% else %>
      <%= link_to "Войти", new_user_session_path, style: "margin-right: 10px;" %>
      <%= link_to "Регистрация", new_user_registration_path %>
    <% end %>
  </nav>


  <div class="d-flex flex-column flex-md-row align-items-center p-3 px-md-4 mb-3 bg-white border-bottom shadow-sm">
    <h5 class="my-0 mr-md-auto font-weight-bold">Family Realm</h5>
    <nav class="my-2 my-md-0 mr-md-3">
      <span class="p-2 text-dark"><%= link_to "Главная страница", posts_path %></span> <!-- кнопка link_to -->

      <span class="p-2 text-dark"><%= link_to "Про нас", about_path %></span> <!-- кнопка link_to -->

      <span class="p-2 text-dark"><%= link_to "Архив", archives_path %></span>

      <% if admin? %>
      <span class="p-2 text-dark">
        <%= link_to "Добавление статьи", new_post_path %>
      </span>
      <% end %>
    </nav>
  </div>

<!-- при создании devise для регистрации -->
<div class="container">
  <% if notice %>
    <div class="alert alert-success"><%= notice %></div>
  <% end %>

  <% if alert %>
    <div class="alert alert-danger"><%= alert %></div>
  <% end %>

  <%= yield %>
</div>
</body>
</html>

