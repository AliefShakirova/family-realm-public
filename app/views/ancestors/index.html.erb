<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="fa-solid fa-users text-primary me-2"></i> Персоны группы</h2>
    <%= link_to "+ Добавить персону", new_group_ancestor_path(@group), class: "btn btn-primary shadow-sm" %>
  </div>

  <div class="row">
    <% if @ancestors.any? %>
      <% @ancestors.each do |person| %>
        <div class="col-md-4 mb-4">
          <div class="card shadow-sm h-100 border-0">
            <div class="card-body text-center p-4">

              <div class="mb-3">
                <div class="d-inline-flex align-items-center justify-content-center bg-light text-primary rounded-circle" style="width: 80px; height: 80px; font-size: 2rem;">
                  <i class="fa-solid fa-user"></i>
                </div>
              </div>

              <h5 class="card-title fw-bold mb-1"><%= person.full_name %></h5>

              <p class="text-muted small mb-3">
                <% if person.birth_date.present? %>
                  <%= person.birth_date.strftime("%Y") %> – <%= person.death_date.present? ? person.death_date.strftime("%Y") : "н.в." %>
                <% else %>
                  <span class="text-light-muted">Даты не указаны</span>
                <% end %>
              </p>

              <%= link_to "Перейти в профиль", group_ancestor_path(@group, person), class: "btn btn-outline-primary btn-sm w-100 stretched-link" %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12">
        <div class="card border-0 shadow-sm text-center py-5">
          <div class="card-body text-muted">
            <i class="fa-solid fa-user-plus fa-3x mb-3 text-light"></i>
            <h4>В этой группе пока нет персон</h4>
            <p>Добавьте первого родственника, чтобы начать строить семейное древо.</p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>