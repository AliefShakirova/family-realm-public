<h1><%= @ancestor.last_name %> <%= @ancestor.first_name %> <%= @ancestor.middle_name %></h1>

<div class="row">
  <div class="col-md-4">
    <% if @ancestor.avatar.attached? %>
      <%= image_tag @ancestor.avatar, class: "img-fluid rounded mb-3" %>
    <% else %>
      <div class="alert alert-secondary">Zdjęcia nie ma</div>
    <% end %>
  </div>

  <div class="col-md-8">
    <p class="lead"><%= @ancestor.description %></p>

    <table class="table table-borderless">
      <tr>
        <th>Data urodzenia:</th>
        <td><%= @ancestor.birth_date %> (<%= @ancestor.birth_place %>)</td>
      </tr>

      <% if @ancestor.alive? %>
        <tr>
          <th>Status:</th>
          <td><span class="badge bg-success">Żyje</span></td>
        </tr>
        <tr>
          <th>Numer telefonu:</th>
          <td><%= @ancestor.phone %></td>
        </tr>
        <tr>
          <th>Adres:</th>
          <td><%= @ancestor.current_address %></td>
        </tr>
      <% else %>
        <tr>
          <th>Status:</th>
          <td><span class="badge bg-secondary">Zmarł</span></td>
        </tr>
        <tr>
          <th>Data śmierci:</th>
          <td><%= @ancestor.death_date %> (<%= @ancestor.death_place %>)</td>
        </tr>
      <% end %>
    </table>
  </div>
</div>

<hr>

<h3>Dokumenty</h3>
<% if @ancestor.documents.attached? %>
  <div class="mb-4">
    <% @ancestor.documents.each do |doc| %>
      <%= link_to doc.filename, doc, class: "btn btn-outline-primary btn-sm me-2 mb-2", target: "_blank" %><br>
    <% end %>
  </div>
<% else %>
  <p class="text-muted">Dokumentów nie ma</p>
<% end %>

<hr>

<h3>Rodzina</h3>

<%= render "relationships/form", group: @group, ancestor: @ancestor, new_relationship: @new_relationship %>

<ul class="list-group mt-3">
  <% if @ancestor.active_relationships.any? %>
    <%= render partial: "relationships/relationship",
               collection: @ancestor.active_relationships,
               locals: { group: @group, ancestor: @ancestor } %>
  <% else %>
    <li class="list-group-item text-muted">Powiązania rodzinne nie zostały jeszcze dodane</li>
  <% end %>
</ul>

<h3>Rodzice</h3>
<ul>
  <% @ancestor.active_relationships.where(relation_type: ['father', 'mother']).each do |rel| %>
    <li><%= link_to rel.relative.full_name, group_ancestor_path(@group, rel.relative) %> (<%= rel.relation_type %>)</li>
  <% end %>

  <% @ancestor.passive_relationships.where(relation_type: 'child').each do |rel| %>
    <li><%= link_to rel.ancestor.full_name, group_ancestor_path(@group, rel.ancestor) %> (Rodzic)</li>
  <% end %>
</ul>

<h3>Dzieci</h3>
<ul>
  <% @ancestor.active_relationships.where(relation_type: 'child').each do |rel| %>
    <li><%= link_to rel.relative.full_name, group_ancestor_path(@group, rel.relative) %></li>
  <% end %>

  <% @ancestor.passive_relationships.where(relation_type: ['father', 'mother']).each do |rel| %>
    <li><%= link_to rel.ancestor.full_name, group_ancestor_path(@group, rel.ancestor) %></li>
  <% end %>
</ul>

<h3>Супруги</h3>
<ul>
  <% spouses = @ancestor.active_relationships.where(relation_type: 'spouse').map(&:relative) +
    @ancestor.passive_relationships.where(relation_type: 'spouse').map(&:ancestor) %>

  <% spouses.each do |spouse| %>
    <li><%= link_to spouse.full_name, group_ancestor_path(@group, spouse) %></li>
  <% end %>
</ul>

<div class="card shadow-sm mt-4">
  <div class="card-header bg-light">
    <h4 class="mb-0">Chronologia wydarzeń</h4>
  </div>

  <div class="card-body p-0">
    <% if @ancestor.events.any? %>
      <div class="list-group list-group-flush">

        <% @ancestor.events.order(event_date: :asc).each do |event| %>
          <%= link_to group_event_path(@group, event), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>

            <div>
              <h6 class="mb-1 fw-bold"><%= event.title %></h6>

              <small class="text-muted">
                <% if event.location %>
                  📍 <%= event.location.name %>
                <% elsif event.location_name.present? %>
                  📍 <%= event.location_name %>
                <% end %>
              </small>
            </div>

            <span class="badge bg-secondary rounded-pill">
              <%= event.event_date.strftime("%d.%m.%Y") if event.event_date %>
            </span>

          <% end %>
        <% end %>

      </div>
    <% else %>
      <div class="p-3 text-muted">
        Wydarzenia dla tej osoby nie zostały jeszcze dodane
        <%= link_to "Dodaj wydarzenie", new_group_event_path(@group), class: "text-decoration-none" %>
      </div>
    <% end %>
  </div>
</div>

<div class="card shadow-sm mt-4 mb-5">
  <div class="card-header bg-light">
    <h4 class="mb-0">Wspomniany w historiach</h4>
  </div>

  <div class="card-body p-0">
    <% if @ancestor.stories.any? %>
      <div class="list-group list-group-flush">

        <% @ancestor.stories.order(created_at: :desc).each do |story| %>
          <%= link_to group_story_path(@group, story), class: "list-group-item list-group-item-action" do %>
            <div class="d-flex w-100 justify-content-between">
              <h6 class="mb-1 fw-bold"><%= story.title %></h6>

              <% if story.story_date %>
                <small class="text-muted border rounded px-2">📅 <%= story.story_date.strftime("%Y") %> год</small>
              <% end %>
            </div>
            <p class="mb-1 text-muted small"><%= truncate(story.content, length: 100) %></p>
          <% end %>
        <% end %>

      </div>
    <% else %>
      <div class="p-3 text-muted">
        Z tą osobą nie wiąże się jeszcze żadna historia
      </div>
    <% end %>
  </div>
</div>

<div class="mt-5">
  <%= link_to "Edytuj dane osoby", edit_group_ancestor_path(@group, @ancestor), class: "btn btn-primary" %>
  <%= link_to "Powrót do listy", group_ancestors_path(@group), class: "btn btn-outline-secondary" %>
</div>