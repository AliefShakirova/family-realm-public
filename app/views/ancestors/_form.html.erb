<%= form_with model: [@group, @ancestor], local: true do |f| %>

  <%= f.label :first_name, "Имя" %>
  <%= f.text_field :first_name %>

  <%= f.label :last_name, "Фамилия" %>
  <%= f.text_field :last_name %>

  <%= f.label :middle_name, "Отчество" %>
  <%= f.text_field :middle_name %>

  <%= f.label :birth_date, "Дата рождения" %>
  <%= f.date_field :birth_date %>

  <%= f.label :birth_place, "Место рождения" %>
  <%= f.text_field :birth_place %>

  <hr>

  <div>
    <%= f.check_box :alive, id: "alive_checkbox" %>
    <%= f.label :alive, "Персона жив(а)" %>
  </div>

  <hr>

  <div id="alive_fields">
    <h4>Если жив</h4>
    <%= f.label :phone, "Телефон" %>
    <%= f.text_field :phone %>

    <%= f.label :current_address, "Адрес проживания" %>
    <%= f.text_field :current_address %>
  </div>

  <div id="dead_fields">
    <h4>Если умер</h4>
    <%= f.label :death_date, "Дата смерти" %>
    <%= f.date_field :death_date %>

    <%= f.label :death_place, "Место смерти" %>
    <%= f.text_field :death_place %>
  </div>

  <hr>

  <%= f.label :description, "Описание" %>
  <%= f.text_area :description %>

  <%= f.label :photo, "Фото (аватар)" %>
  <%= f.file_field :photo %>

  <div class="field">
    <%= f.label :documents, "Загрузить новые документы" %>
    <%= f.file_field :documents, multiple: true %>
  </div>

  <div class="mb-3">
    <%= f.label :gender, "Пол" %><br>
    <%= f.select :gender, ["Мужчина", "Женщина", "kobieta", "mężczyzna"], include_blank: "Не указано" %>
  </div>

  <div style="margin-top: 15px; padding: 15px; background-color: #f8f9fa; border-radius: 5px; border: 1px solid #e9ecef;">
    <h5 style="margin-bottom: 15px;">👨‍👩‍👦 Родители (для построения Древа)</h5>

    <div>
      <%= f.label :father_id, "Отец" %><br>
      <%= f.collection_select :father_id, Ancestor.where.not(id: f.object.id), :id, :full_name, { include_blank: "Не известен / Не указан" }, { style: "width: 100%; padding: 5px;" } %>
    </div>

    <div style="margin-top: 15px;">
      <%= f.label :mother_id, "Мать" %><br>
      <%= f.collection_select :mother_id, Ancestor.where.not(id: f.object.id), :id, :full_name, { include_blank: "Не известна / Не указана" }, { style: "width: 100%; padding: 5px;" } %>
    </div>
  </div>

  <div class="actions mt-4">
    <%= f.submit "Сохранить", class: "btn btn-primary" %>
  </div>

<div class="actions">
  <%= f.submit "Сохранить изменения" %>
</div>

<% end %>
<hr>

<% if @ancestor.documents.attached? %>
  <h4>Уже загруженные документы:</h4>
  <div class="existing-documents">
    <% @ancestor.documents.each do |document| %>
      <div class="attachment" style="margin-bottom: 10px; border-bottom: 1px solid #eee; padding: 5px;">
        <%= link_to document.filename, rails_blob_path(document, disposition: "attachment"), target: "_blank" %>

        <%= button_to "Удалить файл",
                      purge_document_group_ancestor_path(@group, @ancestor, attachment_id: document.id),
                      method: :delete,
                      class: "btn btn-sm btn-danger",
                      style: "display: inline-block; margin-left: 10px;",
                      form: { style: 'display:inline-block;' }
        %>
      </div>
    <% end %>
  </div>
<% end %>

<script>
    function toggleFields() {
        const checkbox = document.getElementById("alive_checkbox");
        if (!checkbox) return;

        const alive = checkbox.checked;
        const aliveFields = document.getElementById("alive_fields");
        const deadFields = document.getElementById("dead_fields");

        if (aliveFields && deadFields) {
            aliveFields.style.display = alive ? "block" : "none";
            deadFields.style.display = alive ? "none" : "block";
        }
    }

    document.addEventListener("turbo:load", function () {
        toggleFields();
        const checkbox = document.getElementById("alive_checkbox");
        if (checkbox) {
            checkbox.addEventListener("change", toggleFields);
        }
    });
</script>