<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Места семьи</h1>
  <%= link_to "Добавить новое место", new_group_location_path(@group), class: "btn btn-success" %>
</div>

<% if @locations.any? %>
  <div class="row">
    <% @locations.each do |location| %>
      <div class="col-md-6 mb-4">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><%= link_to location.name, group_location_path(@group, location), class: "text-decoration-none" %></h5>

            <% if location.address.present? %>
              <h6 class="card-subtitle mb-2 text-muted">📍 <%= location.address %></h6>
            <% end %>

            <p class="card-text text-truncate"><%= location.description %></p>
          </div>
          <div class="card-footer bg-transparent border-top-0">
            <div class="btn-group w-100">
              <%= link_to "Подробнее", group_location_path(@group, location), class: "btn btn-sm btn-outline-primary" %>
              <%= link_to "Изменить", edit_group_location_path(@group, location), class: "btn btn-sm btn-outline-secondary" %>

              <%= button_to "Удалить",
                            group_location_path(@group, location),
                            method: :delete,
                            form: { style: 'display:inline-block;' },
                            class: "btn btn-sm btn-outline-danger w-100" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info text-center">
    <h4>Здесь пока пусто 🌍</h4>
    <p>Добавьте памятные места вашей семьи: дома, города, места захоронений.</p>
    <%= link_to "Добавить первое место", new_group_location_path(@group), class: "btn btn-primary mt-2" %>
  </div>
<% end %>

<%= link_to "Назад в группу", group_path(@group), class: "btn btn-secondary mt-3" %>