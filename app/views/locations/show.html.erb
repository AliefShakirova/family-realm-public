<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h2 class="mb-0"><%= @location.name %></h2>
    <div>
      <%= link_to "Edytuj", edit_group_location_path(@group, @location), class: "btn btn-sm btn-outline-primary" %>
      <%= button_to "Usunąć",
                    group_location_path(@group, @location),
                    method: :delete,
                    class: "btn btn-sm btn-danger ms-2",
                    form: { style: 'display:inline-block;' } %>
    </div>
  </div>

  <div class="card-body">
    <% if @location.address.present? %>
      <p class="lead"><strong> Adres:</strong> <%= @location.address %></p>
    <% end %>

    <hr>

    <h5>Opis</h5>
    <% if @location.description.present? %>
      <p style="white-space: pre-wrap;"><%= @location.description %></p>
    <% else %>
      <p class="text-muted">Brak opisu</p>
    <% end %>

    <hr class="mt-5">
    <h4>Wydarzenia w tym miejscu:</h4>
    <p class="text-muted">Na razie nie ma żadnych wydarzeń</p>

  </div>
</div>

<div class="mt-3">
  <%= link_to "Do listy miejsc", group_locations_path(@group), class: "btn btn-outline-secondary" %>
</div>