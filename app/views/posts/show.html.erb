
<h1><%= @post.title %></h1>
<p><%= @post.body %></p>
<hr>
<% if admin? %>
  <%= link_to "Edytuj", edit_post_path(@post) %> |

  <%= button_to "Usuń",
                post_path(@post),
                method: :delete,
                data: { confirm: "Usunąć post?" },
                class: "btn btn-danger" %>

<% end %>