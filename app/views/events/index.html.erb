<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Хроника семьи</h1>
  <%= link_to "Добавить событие", new_group_event_path(@group), class: "btn btn-success" %>
</div>

<% if @events.any? %>
  <div class="list-group">
    <% @events.each do |event| %>
      <%= link_to group_event_path(@group, event), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-start" do %>

        <div class="ms-2 me-auto">
          <div class="fw-bold fs-5"><%= event.title %></div>

          <div class="text-muted small mt-1">
            <i class="bi bi-calendar"></i> <%= event.event_date.strftime("%d.%m.%Y") %>

            <% if event.location %>
              <span class="ms-3">📍 <%= event.location.name %></span>
            <% end %>
          </div>

          <% if event.ancestors.any? %>
            <div class="mt-2 text-primary small">
              Участники: <%= event.ancestors.map(&:first_name).join(", ") %>
            </div>
          <% end %>
        </div>

      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info text-center mt-4">
    <h4>История пока не написана 📜</h4>
    <p>Добавьте важные даты: дни рождения, свадьбы, переезды или выпускные.</p>
    <%= link_to "Добавить первое событие", new_group_event_path(@group), class: "btn btn-primary" %>
  </div>
<% end %>